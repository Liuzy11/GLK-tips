---
import Layout from '../layouts/Layout.astro';

import DocCard from '../components/DocCard.astro';
import { groupDocsByCategory, loadManifestForSite } from "../data/manifestLoader";

const { siteTitle, docs } = await loadManifestForSite();
const sections = groupDocsByCategory(docs);
---

<Layout title="资料平台">
	<h1 class="pageTitle">{siteTitle}</h1>
	<p class="pageSub">按“卡片”打开分块资料；支持图片预览与下载（转换完成后）。</p>

	{sections.map(({ category, docs }) => (
		<section class="section" aria-label={category}>
			<h2 class="sectionTitle">{category}</h2>
			<div class="cardGrid">
				{docs.map((doc) => (
					<DocCard doc={doc} />
				))}
			</div>
		</section>
	))}
</Layout>
