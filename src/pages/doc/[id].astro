---
import Layout from "../../layouts/Layout.astro";
import type { DocEntry } from "../../data/manifest";
import { loadManifestForSite } from "../../data/manifestLoader";

export async function getStaticPaths() {
	const { docs } = await loadManifestForSite();
	return docs.map((doc) => ({ params: { id: doc.id } }));
}

const { id } = Astro.params as { id: string };
const { docs } = await loadManifestForSite();
const doc: DocEntry | undefined = docs.find((d) => d.id === id);

const hasDownload = !!(doc?.download?.originalDocxHref);
const hasZip = !!(doc?.download?.previewZipHref);
const hasImages = doc?.preview?.kind === "images";
---

<Layout title={doc ? doc.title : "资料不存在"}>
	{doc ? (
		<>
			<h1 class="pageTitle">{doc.title}</h1>
			{doc.description ? <p class="pageSub">{doc.description}</p> : null}

			<div class="twoCol">
				<section class="panel" aria-label="预览区">
					<div class="sectionTitle">文件预览</div>
					{hasImages ? (
						<div class="preview">
							{Array.from({ length: (doc.preview as any).pageCount }, (_, i) => (
								<div class="previewImg" style="overflow:hidden;">
									<img
										src={(doc.preview as any).pageSrc(i + 1)}
										alt={`第 ${i + 1} 页`}
										style="width:100%; height:auto; display:block;"
										loading={i === 0 ? "eager" : "lazy"}
									/>
								</div>
							))}
						</div>
					) : (
						<div class="docPreviewPlaceholder">
							<div class="docPreviewIcon">
								<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
									<rect x="6" y="4" width="28" height="36" rx="4" fill="rgba(0,122,255,0.10)" stroke="rgba(0,122,255,0.25)" stroke-width="1.5"/>
									<path d="M34 4 L42 12 L34 12 Z" fill="rgba(0,122,255,0.15)" stroke="rgba(0,122,255,0.20)" stroke-width="1"/>
									<rect x="6" y="4" width="28" height="36" rx="4" fill="none" stroke="rgba(0,122,255,0.25)" stroke-width="1.5"/>
									<path d="M13 18 H31 M13 24 H28 M13 30 H24" stroke="rgba(0,122,255,0.35)" stroke-width="1.5" stroke-linecap="round"/>
								</svg>
							</div>
							<p class="docPreviewName">{doc.title}</p>
							<p class="docPreviewHint">点击下方按钮下载后即可在本地查看</p>
						</div>
					)}
				</section>

				<aside class="panel" aria-label="下载区">
					<div class="sectionTitle">保存文件</div>
					<div class="downloadRow">
						<a
							class="btn btnPrimary"
							href={hasDownload ? doc.download.originalDocxHref! : "#"}
							aria-disabled={hasDownload ? undefined : "true"}
							download
						>
							<svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M7.5 1v9M4 7l3.5 3.5L11 7M2 13h11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
							下载文件
						</a>
						{hasZip && (
							<a
								class="btn"
								href={doc.download.previewZipHref!}
								download
							>
								<svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M2 4h11v8a1 1 0 01-1 1H3a1 1 0 01-1-1V4zm3-3h5l1 3H4L5 1z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" fill="none"/></svg>
								下载图片包
							</a>
						)}
					</div>
				</aside>
			</div>
		</>
	) : (
		<p class="muted">未找到该资料条目。</p>
	)}
</Layout>
