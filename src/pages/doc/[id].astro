---
import Layout from "../../layouts/Layout.astro";
import type { DocEntry } from "../../data/manifest";
import { loadManifestForSite } from "../../data/manifestLoader";

export async function getStaticPaths() {
	const { docs } = await loadManifestForSite();
	return docs.map((doc) => ({ params: { id: doc.id } }));
}

const { id } = Astro.params as { id: string };
const { docs } = await loadManifestForSite();
const doc: DocEntry | undefined = docs.find((d) => d.id === id);

const hasDownload = !!(doc?.download?.originalDocxHref);
const hasZip = !!(doc?.download?.previewZipHref);
---

<Layout title={doc ? doc.title : "资料不存在"}>
	{doc ? (
		<>
			<h1 class="pageTitle">{doc.title}</h1>
			{doc.description ? <p class="pageSub">{doc.description}</p> : null}

			<div class="docDetailCard panel">
				<div class="docDetailIcon">
					<svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
						<rect x="6" y="4" width="34" height="44" rx="5" fill="rgba(0,122,255,0.08)" stroke="rgba(0,122,255,0.20)" stroke-width="1.5"/>
						<path d="M40 4 L50 14 L40 14 Z" fill="rgba(0,122,255,0.12)" stroke="rgba(0,122,255,0.18)" stroke-width="1"/>
						<path d="M14 22 H38 M14 30 H34 M14 38 H28" stroke="rgba(0,122,255,0.30)" stroke-width="1.8" stroke-linecap="round"/>
					</svg>
				</div>
				<div class="docDetailMeta">
					<p class="docDetailName">{doc.title}</p>
					<p class="docDetailHint">下载后可在本地打开查看完整内容</p>
				</div>
				<div class="docDetailActions">
					<a
						class="btn btnPrimary"
						href={hasDownload ? doc.download.originalDocxHref! : "#"}
						aria-disabled={hasDownload ? undefined : "true"}
						download
					>
						<svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M7.5 1v9M4 7l3.5 3.5L11 7M2 13h11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
						下载文件
					</a>
					{hasZip && (
						<a class="btn" href={doc.download.previewZipHref!} download>
							<svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M2 4h11v8a1 1 0 01-1 1H3a1 1 0 01-1-1V4zm3-3h5l1 3H4L5 1z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" fill="none"/></svg>
							下载图片包
						</a>
					)}
				</div>
			</div>
		</>
	) : (
		<p class="muted">未找到该资料条目。</p>
	)}
</Layout>
